# Copy this file to .env and fill in the values.
# .env is gitignored — never commit it.

# ─── HubSpot ──────────────────────────────────────────────────────────────────
# Service Key created in Phase 1.1 (Settings → Integrations → Service Keys).
# Format: long opaque string. Used as `Authorization: Bearer <key>` on every call.
HUBSPOT_SERVICE_KEY=

# ─── Snowflake ────────────────────────────────────────────────────────────────
# Filled in during Phase 4. One service user per role (least privilege).
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_DATABASE=REVOPS
SNOWFLAKE_WAREHOUSE=REVOPS_WH

SNOWFLAKE_USER_LOADER=
SNOWFLAKE_PASSWORD_LOADER=

SNOWFLAKE_USER_TRANSFORMER=
SNOWFLAKE_PASSWORD_TRANSFORMER=

SNOWFLAKE_USER_REPORTER=
SNOWFLAKE_PASSWORD_REPORTER=

# ─── Telegram (failure notifications) ─────────────────────────────────────────
# Filled in during Phase 11.5.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
