# Streamlit secrets template — copy to .streamlit/secrets.toml (gitignored)
# and fill in the values from your local .env file.
#
# On Streamlit Community Cloud, paste the same key=value lines into the app's
# Settings -> Secrets in the Streamlit UI; no file deploy needed.
#
# Only the REPORTER role's credentials live here — the dashboard never reads
# RAW or STAGING, so LOADER and TRANSFORMER creds stay out of it (least
# privilege carried into the BI layer).

SNOWFLAKE_ACCOUNT            = "your-org-account"
SNOWFLAKE_WAREHOUSE          = "REVOPS_WH"
SNOWFLAKE_DATABASE           = "REVOPS"
SNOWFLAKE_USER_REPORTER      = "REVOPS_REPORTER_USER"
SNOWFLAKE_PASSWORD_REPORTER  = "your-reporter-password"
